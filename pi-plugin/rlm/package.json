{
  "name": "@hicaru/pi-rlm",
  "version": "0.1.2",
  "type": "module",
  "description": "Save 99% tokens, Recursive Language Model (RLM) for the Pi",
  "license": "MIT",
  "author": "hicaru",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hicaru/rlm.pi.git"
  },
  "homepage": "https://github.com/hicaru/rlm.pi",
  "bugs": {
    "url": "https://github.com/hicaru/rlm.pi/issues"
  },
  "files": [
    "src/",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "pi-package",
    "pi-extension",
    "rlm",
    "recursive",
    "ai-agent"
  ],
  "scripts": {
