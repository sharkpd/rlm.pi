  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  },
  "dependencies": {
    "repomix": "^1.15.0"
  },
  "devDependencies": {
    "typescript": "^5.0.0"
  }
}
